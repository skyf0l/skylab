{
  "realm": "skylab",
  "enabled": true,
  "displayName": "skylab",
  "loginWithEmailAllowed": true,
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "grafana-admin", "description": "Grafana org admin" }
    ]
  },
  "groups": [
    { "name": "grafana-admins", "realmRoles": ["grafana-admin"] },
    { "name": "argocd-admins" }
  ],
  "clients": [
    {
      "clientId": "grafana",
      "name": "Grafana",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "$(env:GRAFANA_OIDC_SECRET)",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["https://grafana.tail.skyf0l.dev/login/generic_oauth"],
      "webOrigins": ["https://grafana.tail.skyf0l.dev"],
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "argocd",
      "name": "ArgoCD",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "$(env:ARGOCD_OIDC_SECRET)",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "https://argocd.tail.skyf0l.dev/auth/callback",
        "http://localhost:8085/auth/callback"
      ],
      "webOrigins": ["https://argocd.tail.skyf0l.dev"],
      "protocolMappers": [
        {
          "name": "group-membership",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ]
}
