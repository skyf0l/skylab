{
  "realm": "skylab",
  "enabled": true,
  "displayName": "skylab",
  "loginWithEmailAllowed": true,
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "grafana-admin",  "description": "Grafana org admin" },
      { "name": "grafana-editor", "description": "Grafana editor" },
      { "name": "argocd-access",  "description": "May log in to ArgoCD (carried by argocd-admins)" }
    ]
  },
  "groups": [
    { "name": "grafana-admins", "realmRoles": ["grafana-admin"] },
    { "name": "argocd-admins",  "realmRoles": ["argocd-access"] }
  ],
  "authenticatorConfig": [
    {
      "alias": "argocd-access-condition",
      "config": { "condUserRole": "argocd-access", "negate": "true" }
    }
  ],
  "authenticationFlows": [
    {
      "alias": "argocd-browser",
      "description": "Browser flow for the argocd client: deny login unless the user has argocd-access",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "auth-cookie", "requirement": "ALTERNATIVE", "priority": 10, "userSetupAllowed": false, "autheticatorFlow": false },
        { "flowAlias": "argocd-browser-forms", "requirement": "ALTERNATIVE", "priority": 20, "userSetupAllowed": false, "autheticatorFlow": true },
        { "flowAlias": "argocd-access-gate", "requirement": "CONDITIONAL", "priority": 30, "userSetupAllowed": false, "autheticatorFlow": true }
      ]
    },
    {
      "alias": "argocd-browser-forms",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "auth-username-password-form", "requirement": "REQUIRED", "priority": 10, "userSetupAllowed": false, "autheticatorFlow": false }
      ]
    },
    {
      "alias": "argocd-access-gate",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "conditional-user-role", "requirement": "REQUIRED", "priority": 10, "userSetupAllowed": false, "autheticatorFlow": false, "authenticatorConfig": "argocd-access-condition" },
        { "authenticator": "deny-access-authenticator", "requirement": "REQUIRED", "priority": 20, "userSetupAllowed": false, "autheticatorFlow": false }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "grafana",
      "name": "Grafana",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "$(env:GRAFANA_OIDC_SECRET)",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["https://grafana.tail.skyf0l.dev/login/generic_oauth"],
      "webOrigins": ["https://grafana.tail.skyf0l.dev"],
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "argocd",
      "name": "ArgoCD",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "$(env:ARGOCD_OIDC_SECRET)",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "https://argocd.tail.skyf0l.dev/auth/callback",
        "http://localhost:8085/auth/callback"
      ],
      "webOrigins": ["https://argocd.tail.skyf0l.dev"],
      "authenticationFlowBindingOverrides": { "browser": "argocd-browser" },
      "protocolMappers": [
        {
          "name": "group-membership",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ]
}
